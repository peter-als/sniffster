{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/usr/bin/clang-22",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++-22",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "/usr/bin/clang-scan-deps-22",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "SNIFFSTER_CXX_STDLIB": "libc++"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "sanitized",
      "inherits": "base",
      "displayName": "Sanitized",
      "binaryDir": "${sourceDir}/build/sanitized",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SNIFFSTER_ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "sanitized",
      "configurePreset": "sanitized"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "verbosity": "verbose" }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "verbosity": "verbose" }
    },
    {
      "name": "sanitized",
      "configurePreset": "sanitized",
      "output": { "verbosity": "verbose" },
      "filter": {
        "exclude": {
          "name": "^(ConfigInterfaceTest\\.(ThrowsWhenGetifaddrsFails|ThrowsWhenInterfaceIsMissing|SkipsEntriesWithoutAddress|SkipsEntriesWithoutName|SkipsEntriesWithoutNetmask|SkipsEntriesWithNonIpv4Netmask|ThrowsWhenInterfaceIndexIsMissing)|NetworkMiscTest\\.FsQueueDetectorReturnsMinusOneForExistingNonDirectoryQueuePath|PlatformThrowRuntimeError\\.(PlainMessageIncludesCallSiteContext|FormattedMessageUsesCallerLocation)|XdpCopyModeLoaderTest\\.(ThrowsWhenSkeletonOpenFails|ThrowsWhenPerfMapResizeFails|ThrowsWhenKernelLoadFails|ThrowsWhenNicAttachFailsAndStillDestroysSkeleton)|SnifferRuntimeTest\\.RunThrowsOnNegativePollResult)$"
        }
      }
    }
  ]
}
